{
  "id": "holdout_browser_session_extract",
  "version": 1,
  "kind": "browser",
  "fixture": "benchmarks/fixtures/browser/holdout_session_start.html",
  "expected": "benchmarks/expected/holdout_browser_session_extract.expected.json",
  "ready_condition": {
    "type": "selector",
    "selector": "#session-status",
    "state": "attached",
    "timeout_ms": 10000,
    "wait_ms": 200
  },
  "extract_spec": {
    "strategy": "browser_session_values",
    "fields": {
      "login_user": "#welcome strong::text",
      "session_status": "#session-status::text",
      "cart_count": "#cart-count::text"
    }
  },
  "correctness": {
    "comparison": "exact",
    "required_fields": ["login_user", "session_status", "cart_count"],
    "semantic_match_threshold": 1.0,
    "required_page_texts": ["Holdout session dashboard"],
    "forbidden_page_texts": ["login failed", "challenge"]
  },
  "cost_weights": {
    "wall_ms": 0.35,
    "cpu_ms": 0.25,
    "peak_rss_mb": 0.15,
    "load_ms": 0.1,
    "extract_ms": 0.15
  }
}
