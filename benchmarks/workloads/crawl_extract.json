{
  "id": "crawl_extract",
  "version": 1,
  "kind": "static",
  "fixture": "benchmarks/fixtures/static/crawl_page_1.html",
  "fixtures": [
    "benchmarks/fixtures/static/crawl_page_1.html",
    "benchmarks/fixtures/static/crawl_page_2.html"
  ],
  "expected": "benchmarks/expected/crawl_extract.expected.json",
  "ready_condition": {
    "type": "immediate"
  },
  "extract_spec": {
    "strategy": "multi_fixture_record_css",
    "item_selector": ".product-card",
    "fields": {
      "title": ".title::text",
      "price": ".price::text",
      "url": "a::attr(href)"
    }
  },
  "correctness": {
    "comparison": "exact",
    "required_fields": ["title", "price", "url"],
    "semantic_match_threshold": 1.0
  },
  "cost_weights": {
    "wall_ms": 0.35,
    "cpu_ms": 0.25,
    "peak_rss_mb": 0.15,
    "load_ms": 0.1,
    "extract_ms": 0.15
  }
}
