{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scrapling Benchmark Workload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "kind",
    "fixture",
    "expected",
    "extract_spec",
    "correctness",
    "cost_weights"
  ],
  "properties": {
    "id": {"type": "string"},
    "version": {"type": "integer"},
    "kind": {"type": "string"},
    "fixture": {"type": "string"},
    "fixtures": {
      "type": "array",
      "items": {"type": "string"}
    },
    "expected": {"type": "string"},
    "ready_condition": {"type": "object"},
    "extract_spec": {"type": "object"},
    "correctness": {"type": "object"},
    "cost_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_ms", "cpu_ms", "peak_rss_mb", "load_ms", "extract_ms"],
      "properties": {
        "wall_ms": {"type": "number", "minimum": 0},
        "cpu_ms": {"type": "number", "minimum": 0},
        "peak_rss_mb": {"type": "number", "minimum": 0},
        "load_ms": {"type": "number", "minimum": 0},
        "extract_ms": {"type": "number", "minimum": 0}
      }
    }
  }
}
